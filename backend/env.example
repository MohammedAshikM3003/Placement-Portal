# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Server Configuration
PORT=5000
NODE_ENV=development

# Admin Credentials (for initial setup)
ADMIN_ID=admin
ADMIN_PASSWORD=admin123

# Coordinator Credentials (for initial setup)
COORDINATOR_ID=coord_cse
COORDINATOR_PASSWORD=coord123
COORDINATOR_DEPARTMENT=CSE

# Mail & OTP Transport Configurations
MAIL_PROVIDER=gmail
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME="K S R College of Engineering - Placement Cell"
MAIL_FROM_ADDRESS=your-email@gmail.com

# Institutional SMTP Settings
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_SECURE=false
PORTAL_URL=http://localhost:3000
