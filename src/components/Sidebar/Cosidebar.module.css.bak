.sidebar {
  background: #fff;
  width: 290px;
  height: calc(100vh - 65px);
  box-shadow: 2px 0 12px #e1e6ef3a;
  display: flex;
  flex-direction: column;
  position: fixed;
  left: 0;
  top: 65px;
  overflow-y: auto;
  overflow-x: hidden;
  z-index: 1002;
  transition: transform 0.3s ease-in-out;
}

/* Standalone .open class to prevent CSS Module undefined issues */
.open {
  transform: translateX(0) !important;
}

/* --- NEW RESPONSIVE RULES --- */
@media (max-width: 1200px) {
  .sidebar {
    /* Hides the sidebar off-screen by default on mobile */
    transform: translateX(-100%);
    width: 280px;
  }
  .sidebar.open {
    /* Slides the sidebar into view when the 'open' class is added */
    transform: translateX(0) !important;
  }
}
/* --- END OF NEW RULES --- */

.sidebar .user-info {
  text-align: center;
  /* Reduced top padding */
  padding: 15px 20px 20px 20px; 
  font-size: 1rem;
  color: #555;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex-shrink: 0;
  margin-top: 15px;
}

.sidebar .user-details img {
  width: 60px;
  height: 60px;
  flex-shrink: 0;
  border-radius: 50%;
  object-fit: cover;
}

.sidebar .user-details {
  margin-top: 8px;
  font-weight: 600;
  font-size: 1.1em;
  color: #191c24;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  width: 100%;
}

.sidebar .user-text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  flex: 1;
  text-align: left;
}

.sidebar .user-text span {
  font-size: 1em;
  font-weight: 600;
  color: #191c24;
  line-height: 1.2;
  word-break: break-word;
  text-align: left;
}

.sidebar .nav {
  display: flex;
  flex-direction: column;
  padding: 0px 0;
  justify-content: flex-start;
  gap: 0;
  min-height: 0;
}

.sidebar .nav-section {
  display: flex;
  flex-direction: column;
  /* Reduced gap to offset the nav-item margins */
  gap: 0px; 
  flex-shrink: 0;
}

.sidebar .nav-item {
  display: flex;
  align-items: center;
  font-size: 1.27rem;
  /* Reduced vertical padding to save space */
  padding: 12px 25px; 
  color: #000000;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.18s;
  gap: 15px;
  border-left: 4px solid transparent;
  /* Updated margin to create a 20px gap between items */
  margin: 10px 0;
}

.sidebar .nav-item.selected {
  background: #fef5f6;
  border-left: 4px solid #D23B42;
  color: #D23B42;
  font-weight: 600;
}

.sidebar .nav-item.selected img {
  filter: brightness(0) saturate(100%) invert(24%) sepia(98%) saturate(2522%) hue-rotate(340deg) brightness(85%) contrast(107%);
}

.sidebar .nav-item:hover:not(.selected) {
  background: #fef5f6;
  border-left: 4px solid #D23B42;
  color: #D23B42;
}

.sidebar .nav-item img {
  width: 20px;
  height: 20px;
  transition: transform 0.2s;
  filter: brightness(0) saturate(100%) invert(0%) sepia(0%) saturate(0%) hue-rotate(0deg) brightness(0%) contrast(100%);
}

.sidebar .nav-item:hover img {
  transform: scale(1.1);
}

.sidebar .nav-item:hover:not(.selected) img {
  filter: brightness(0) saturate(100%) invert(24%) sepia(98%) saturate(2522%) hue-rotate(340deg) brightness(85%) contrast(107%);
}

.sidebar .nav-divider {
  height: 1px;
  width: 85%;
  background: #e0e0e0;
  margin: 8px auto;
  border-top: 1px dotted #ccc;
  flex-shrink: 0;
  margin-top: 12px;
}

.sidebar .logout-btn {
    background: #D23B42;
    color: #fff;
    padding: 12px 0;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
    width: calc(100% - 40px);
    margin: 10px 20px 20px 20px;
}

.sidebar .logout-btn:hover {
  background: #d55a6a;
}

.overlay {
  display: none;
}

@media (max-width: 1200px) {
  .overlay {
    display: block;
    position: fixed;
    top: 65px;
    left: 0;
    width: 100vw;
    height: calc(100vh - 65px);
    background-color: rgba(0, 0, 0, 0.4);
    z-index: 1001;
  }
}
