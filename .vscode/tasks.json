{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "start-backend",
			"type": "shell",
			"command": "Set-Location 'backend'; npm start",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "start-frontend",
			"type": "shell",
			"command": "npm start",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "start-frontend-3001",
			"type": "shell",
			"command": "$env:PORT='3001'; npm start",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "check-port-3000",
			"type": "shell",
			"command": "netstat -ano | findstr :3000",
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "start-frontend-3000",
			"type": "shell",
			"command": "$env:PORT='3000'; npm start",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "frontend-build",
			"type": "shell",
			"command": "npm run build",
			"isBackground": false,
			"group": "build"
		}
	]
}